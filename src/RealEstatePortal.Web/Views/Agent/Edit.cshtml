@model AgentFormModel

@{
    ViewData["Title"] = "Edit profile";
}

<div class="container py-5">
    
	<div class="mb-5">
		<h1 class="fw-bold mb-2">Edit profile</h1>
	</div>

	<form method="post" asp-action="Edit" asp-controller="Agent" onsubmit="this.querySelector('button[type=submit]').disabled = true;">
		<div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

		<div class="row g-4">
            
			<div class="col-lg-6">
                
				<div class="form-card">
					<h5>Main info</h5>
                    
					<div class="d-flex align-items-center gap-3 mb-3">
						<img src="@Model.AvatarUrl" class="rounded object-fit-cover" style="width: 70px; height: 70px;" alt="Profile" onerror="this.src='/images/default-avatar.png'">
						
						<div class="input-group-custom mb-0 flex-grow-1">
							<label class="form-label-custom">Avatar link</label>
							<input asp-for="AvatarUrl" class="form-control" placeholder="Enter url link" />
							<span asp-validation-for="AvatarUrl" class="text-danger small"></span>
						</div>
					</div>

					<div class="input-group-custom">
						<label class="form-label-custom">Full name</label>
						<input asp-for="FullName" class="form-control" placeholder="Enter full name" />
						<span asp-validation-for="FullName" class="text-danger small"></span>
					</div>

					<div class="input-group-custom">
						<label class="form-label-custom">Address</label>
						<input asp-for="Address" class="form-control" placeholder="Enter address" />
						<span asp-validation-for="Address" class="text-danger small"></span>
					</div>

					<div class="input-group-custom mb-0">
						<label class="form-label-custom">Phone number</label>
						<input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
						<span asp-validation-for="PhoneNumber" class="text-danger small"></span>
					</div>
				</div>

				<div class="form-card mt-4">
					<h5>Work time</h5>
                    
					<label class="form-label-custom">Work days</label>
					<div class="row g-3 mb-3">
						<div class="col-6">
							<select asp-for="WorkingDaysStart" class="form-select">
								<option value="">From</option>
								<option value="Monday">Monday</option>
								<option value="Tuesday">Tuesday</option>
								<option value="Wednesday">Wednesday</option>
								<option value="Thursday">Thursday</option>
								<option value="Friday">Friday</option>
								<option value="Saturday">Saturday</option>
								<option value="Sunday">Sunday</option>
							</select>
						</div>
						<div class="col-6">
							<select asp-for="WorkingDaysEnd" class="form-select">
								<option value="">To</option>
								<option value="Monday">Monday</option>
								<option value="Tuesday">Tuesday</option>
								<option value="Wednesday">Wednesday</option>
								<option value="Thursday">Thursday</option>
								<option value="Friday">Friday</option>
								<option value="Saturday">Saturday</option>
								<option value="Sunday">Sunday</option>
							</select>
						</div>
					</div>

					<div class="row g-3 mb-3">
						<div class="col-6">
							<input type="time" asp-for="WorkingHoursStart" class="form-control" />
						</div>
						<div class="col-6">
							<input type="time" asp-for="WorkingHoursEnd" class="form-control" />
						</div>
					</div>

					<div>
						<label class="form-label-custom">Rest days</label>
						<input asp-for="RestDays" class="form-control" placeholder="Saturday, Sunday" />
					</div>
				</div>

			</div>

			<div class="col-lg-6">
                
				<div class="form-card">
					<h5>Description</h5>
					<div class="input-group-custom mb-0">
						<textarea asp-for="Description" class="form-control" rows="11" placeholder="Describe yourself"></textarea>
						<span asp-validation-for="Description" class="text-danger small"></span>
					</div>
				</div>

				<div class="form-card mt-4">
					<h5>Socials</h5>
					<div class="input-group-custom">
						<label class="form-label-custom">Facebook</label>
						<input asp-for="FacebookUrl" class="form-control" placeholder="link.com" />
					</div>
					<div class="input-group-custom">
						<label class="form-label-custom">Website</label>
						<input asp-for="WebsiteUrl" class="form-control" placeholder="link.com" />
					</div>
					<div class="input-group-custom mb-0">
						<label class="form-label-custom">Instagram</label>
						<input asp-for="InstagramUrl" class="form-control" placeholder="link.com" />
					</div>
				</div>

				<div class="form-card mt-4">
					<h5>Spoken languages</h5>
					<div class="input-group-custom mb-0">
						<input asp-for="SpokenLanguages" class="form-control" placeholder="English, Bulgarian or etc." />
						<span asp-validation-for="SpokenLanguages" class="text-danger small"></span>
					</div>
				</div>

			</div>
		</div>

		<div class="d-flex justify-content-end mt-4 mb-5">
			<button type="submit" class="btn btn-theme fs-5">Save changes</button>
		</div>

	</form>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}