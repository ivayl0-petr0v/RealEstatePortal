@model AgentDeleteViewModel

@{
	ViewData["Title"] = "Delete Profile";
}

<div class="container py-5 d-flex justify-content-center">
	<div class="form-card text-center" style="max-width: 500px;">
        
		<i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
        
		<h2 class="fw-bold mt-3 mb-2">Delete profile?</h2>
		<p class="text-muted mb-4">
			Are you sure you want to delete the profile of <strong>@Model.FullName</strong>? 
			This action cannot be undone, but your listings will remain archived.
		</p>

		<form asp-action="Delete" asp-controller="Agent" method="post" onsubmit="this.querySelector('button[type=submit]').disabled = true;">
			<div class="d-flex justify-content-center gap-3 mt-4">
				<a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light rounded-pill px-4 border">
					Cancel
				</a>
				<button type="submit" class="btn btn-danger rounded-pill px-4">
					Yes, delete it
				</button>
			</div>
		</form>
	</div>
</div>