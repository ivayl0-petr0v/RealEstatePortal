@model AgentDetailsViewModel
@using System.Security.Claims

@{
	ViewData["Title"] = Model.FullName;
}

<div class="container py-5">
    
	<div class="form-card mb-4 position-relative">
		@if (User.Identity?.IsAuthenticated == true && User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.UserId)
		{
			<div class="position-absolute top-0 end-0 mt-4 me-4">
				<button class="btn btn-light rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown">
					<i class="bi bi-three-dots"></i>
				</button>
				<ul class="dropdown-menu dropdown-menu-end border-0 shadow">
					<li><a class="dropdown-item" asp-controller="Agent" asp-action="Edit" asp-route-id="@Model.Id">Edit profile</a></li>
					<li><hr class="dropdown-divider"></li>
					<li><a class="dropdown-item text-danger" asp-controller="Agent" asp-action="Delete" asp-route-id="@Model.Id">Delete profile</a></li>
				</ul>
			</div>
		}
		<div class="d-flex flex-column flex-md-row align-items-md-center gap-4">
			<img src="@Model.AvatarUrl" class="rounded avatar-img" alt="@Model.FullName" onerror="this.src='/images/default-avatar.png'">
            
			<div class="flex-grow-1">
				<h2 class="fw-bold mb-3">@Model.FullName</h2>
                
				<div class="d-flex flex-wrap gap-4 text-muted">
					<div class="d-flex align-items-center">
						<i class="bi bi-geo-alt me-2 fs-5"></i>
						<span>@Model.Address</span>
					</div>
					<div class="d-flex align-items-center">
						<i class="bi bi-telephone me-2 fs-5"></i>
						<span>@Model.PhoneNumber</span>
					</div>
					@if (!string.IsNullOrEmpty(Model.Email))
					{
						<div class="d-flex align-items-center">
							<i class="bi bi-envelope me-2 fs-5"></i>
							<span>@Model.Email</span>
						</div>
					}
				</div>
			</div>
		</div>
	</div>

	<div class="row g-4 mb-5">
		<div class="col-lg-7">
			<div class="form-card h-100">
				<h5 class="mb-3">Description</h5>
				<p class="text-muted mb-0" style="line-height: 1.6; text-align: justify;">
					@Model.Description
				</p>
			</div>
		</div>

		<div class="col-lg-5 d-flex flex-column gap-4">
			<div class="form-card">
				<h5 class="mb-4">Work time</h5>
				<div class="row g-3">
					<div class="col-sm-6 d-flex align-items-start gap-3">
						<div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
							<i class="bi bi-calendar4-week text-muted"></i>
						</div>
						<div>
							<small class="text-muted d-block">Work days</small>
							<span class="d-block text-dark small fw-medium">@Model.WorkingDays</span>
							<span class="d-block text-dark small">@Model.WorkingHours</span>
						</div>
					</div>
					<div class="col-sm-6 d-flex align-items-start gap-3">
						<div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
							<i class="bi bi-cup-hot text-muted"></i>
						</div>
						<div>
							<small class="text-muted d-block">Rest days</small>
							<span class="d-block text-dark small fw-medium">@Model.RestDays</span>
						</div>
					</div>
				</div>
			</div>

			<div class="form-card">
				<h5 class="mb-3">Spoken languages</h5>
				<p class="text-muted mb-0">
					@(Model.SpokenLanguages.Any() ? string.Join(", ", Model.SpokenLanguages) : "None specified")
				</p>
			</div>

			<div class="form-card">
				<h5 class="mb-3">Socials</h5>
				<div class="d-flex flex-wrap gap-4">
					@if (!string.IsNullOrEmpty(Model.FacebookUrl))
					{
						<a href="@Model.FacebookUrl" target="_blank" class="text-decoration-none text-muted small d-flex align-items-center gap-2 social-link">
							<i class="bi bi-facebook"></i> Facebook
						</a>
					}
					@if (!string.IsNullOrEmpty(Model.WebsiteUrl))
					{
						<a href="@Model.WebsiteUrl" target="_blank" class="text-decoration-none text-muted small d-flex align-items-center gap-2 social-link">
							<i class="bi bi-globe"></i> Website
						</a>
					}
					@if (!string.IsNullOrEmpty(Model.InstagramUrl))
					{
						<a href="@Model.InstagramUrl" target="_blank" class="text-decoration-none text-muted small d-flex align-items-center gap-2 social-link">
							<i class="bi bi-instagram"></i> Instagram
						</a>
					}
				</div>
			</div>
		</div>
	</div>

	<div class="mt-5">
		<div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
			<h3 class="fw-bold mb-0">Agent's properties</h3>
		</div>

		@if (Model.AgentRealEstates == null || !Model.AgentRealEstates.Any())
		{
			<div class="text-center py-5 bg-white rounded-4 shadow-sm border-0 form-card">
				<i class="bi bi-house-x text-muted mb-3 d-block" style="font-size: 2.5rem;"></i>
				<h5 class="fw-bold text-dark mb-2">No listings yet</h5>
				<p class="text-muted mb-0">This agent doesn't have any active property listings right now.</p>
			</div>
		}
		else
		{
			<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
				@foreach (var property in Model.AgentRealEstates)
				{
					<div class="col">
						<a asp-controller="RealEstate" asp-action="Details" asp-route-id="@property.Id" class="text-decoration-none">
							<div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden property-card position-relative">
								
								<form asp-controller="RealEstate" asp-action="ToggleFavorite" asp-route-id="@property.Id" method="post" class="position-absolute top-0 end-0 m-3" style="z-index: 10;">
									<input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
									<button type="submit" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center heart-btn" style="width: 36px; height: 36px;">
										<i class="bi @(property.IsFavorite ? "bi-heart-fill text-danger" : "bi-heart text-dark") fs-6"></i>
									</button>
								</form>

								<img src="@property.ImageUrl" class="card-img-top object-fit-cover" style="height: 200px;" alt="@property.Title" onerror="this.src='/images/default-property.jpg'">
								
								<div class="card-body p-3 d-flex flex-column">
									<h5 class="fw-bold mb-2" style="color: #008C72;">@property.Price.ToString("N0") €</h5>
									
									<div class="d-flex align-items-center text-muted small mb-2 gap-3 flex-wrap">
										<span><i class="bi bi-house me-1"></i> @property.Title</span>
										<span><i class="bi bi-arrows-fullscreen me-1"></i> @property.Area m²</span>
										<span class="text-truncate" style="max-width: 140px;" title="@property.Address"><i class="bi bi-geo-alt me-1"></i> @property.Address</span>
									</div>
									
									<div class="d-flex align-items-center text-muted small gap-3 border-top pt-2 mt-auto">
										<span><i class="bi bi-door-open me-1"></i> @property.RoomsCount rooms</span>
										<span><i class="fas fa-bed me-1" style="font-size: 0.9rem;"></i> @property.BedroomsCount beds</span>
										<span><i class="bi bi-droplet me-1"></i> @property.BathroomsCount baths</span>
									</div>
								</div>
							</div>
						</a>
					</div>
				}
			</div>
		}
	</div>
</div>