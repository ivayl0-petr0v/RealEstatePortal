@model AgentDetailsViewModel


<div class="bg-light py-5">
    <div class="container">
        
        <div class="card border-0 shadow-sm rounded-4 mb-4 position-relative overflow-hidden">
            <div class="row g-0">
                <div class="col-md-3 col-lg-2">
                    <img src="@Model.AvatarUrl" class="img-fluid h-100 w-100 object-fit-cover" alt="@Model.FullName" onerror="this.src='/images/default-avatar.png'" style="min-height: 200px;">
                </div>
                <div class="col-md-9 col-lg-10 p-4 p-md-5 d-flex flex-column justify-content-center">
                    
                    <div class="position-absolute top-0 end-0 p-3">
                        <button class="btn btn-light rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-three-dots"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                            <li><a class="dropdown-item" href="#">Редактирай</a></li>
                            <li><a class="dropdown-item text-danger" href="#">Изтрий профил</a></li>
                        </ul>
                    </div>

                    <h2 class="fw-bold mb-3">@Model.FullName</h2>
                    
                    <div class="d-flex flex-column gap-2 text-muted">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-geo-alt me-2 fs-5"></i>
                            <span>@Model.Address</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-telephone me-2 fs-5"></i>
                            <span>@Model.PhoneNumber</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <div class="d-flex align-items-center">
                                <i class="bi bi-envelope me-2 fs-5"></i>
                                <span>@Model.Email</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                    <h5 class="fw-bold mb-3">Описание</h5>
                    <p class="text-muted mb-0" style="line-height: 1.6; text-align: justify;">
                        @Model.Description
                    </p>
                </div>
            </div>

            <div class="col-lg-5 d-flex flex-column gap-4">
                
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-4">Работно време</h5>
                    <div class="row g-3">
                        <div class="col-sm-6 d-flex align-items-start gap-3">
                            <div class="icon-circle bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-calendar4-week text-muted"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Работни дни</small>
                                <span class="d-block text-dark small fw-medium">@Model.WorkingDays</span>
                                <span class="d-block text-dark small">@Model.WorkingHours</span>
                            </div>
                        </div>
                        <div class="col-sm-6 d-flex align-items-start gap-3">
                            <div class="icon-circle bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-cup-hot text-muted"></i>
                            </div>
                            <div>
                                <small class="text-muted d-block">Почивни дни</small>
                                <span class="d-block text-dark small fw-medium">@Model.RestDays</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-3">Говорими езици</h5>
                    <p class="text-muted mb-0">
                        @(Model.SpokenLanguages.Any() ? string.Join(", ", Model.SpokenLanguages) : "Не са посочени")
                    </p>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h5 class="fw-bold mb-3">Връзки</h5>
                    <div class="d-flex gap-4">
                        @if (!string.IsNullOrEmpty(Model.FacebookUrl))
                        {
                            <a href="@Model.FacebookUrl" target="_blank" class="text-decoration-none text-dark small d-flex align-items-center gap-2 social-link">
                                <i class="bi bi-facebook"></i> Facebook
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                        {
                            <a href="@Model.WebsiteUrl" target="_blank" class="text-decoration-none text-dark small d-flex align-items-center gap-2 social-link">
                                <i class="bi bi-globe"></i> Уебсайт
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.InstagramUrl))
                        {
                            <a href="@Model.InstagramUrl" target="_blank" class="text-decoration-none text-dark small d-flex align-items-center gap-2 social-link">
                                <i class="bi bi-instagram"></i> Instagram
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-white py-5">
    <div class="container">
        
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
            <h3 class="fw-bold mb-0">Agent's listing</h3>
            
            <div class="btn-group rounded-pill border p-1" role="group">
                <button type="button" class="btn btn-dark rounded-pill px-4 btn-sm">All</button>
                <button type="button" class="btn btn-white rounded-pill px-4 text-muted btn-sm border-0">Продажба</button>
                <button type="button" class="btn btn-white rounded-pill px-4 text-muted btn-sm border-0">Наем</button>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <div class="col">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden property-card">
                    <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?q=80&w=600&auto=format&fit=crop" class="card-img-top object-fit-cover" style="height: 200px;" alt="Имот">
                    <div class="card-body p-3">
                        <h5 class="fw-bold text-teal mb-2" style="color: #009688;">147 000 €</h5>
                        <div class="d-flex align-items-center text-muted small mb-2 gap-3">
                            <span><i class="bi bi-house me-1"></i> Апартамент</span>
                            <span><i class="bi bi-arrows-fullscreen me-1"></i> 70 м²</span>
                            <span class="text-truncate"><i class="bi bi-geo-alt me-1"></i> Чаталджа, Варна</span>
                        </div>
                        <div class="d-flex align-items-center text-muted small gap-3 border-top pt-2 mt-2">
                            <span><i class="bi bi-door-open me-1"></i> 3 стаи</span>
                            <span><i class="bi bi-bed me-1"></i> 2 спални</span>
                            <span><i class="bi bi-droplet me-1"></i> 1 баня</span>
                        </div>
                    </div>
                </div>
            </div>
            </div>

    </div>
</div>