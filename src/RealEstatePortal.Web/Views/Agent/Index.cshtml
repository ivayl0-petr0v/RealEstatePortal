@model IEnumerable<AllAgentsViewModel>

@{
	ViewData["Title"] = "Agents";
}

<div class="container mt-5 mb-5">
	<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
		<div class="d-flex align-items-center gap-3">
			<h2 class="mb-0 fw-bold">Agents</h2>
			<a asp-controller="Agent" asp-action="Create" class="btn btn-teal rounded-pill px-4 text-white"">
				Create an agent
			</a>
		</div>

		<div class="d-flex align-items-center">
			<span class="me-2 text-muted small">Sorting</span>
			<select class="form-select rounded-pill shadow-sm border-0 bg-white" style="width: 160px; cursor: pointer;">
				<option value="newest">Newest</option>
				<option value="oldest">Oldest</option>
			</select>
		</div>
	</div>

	<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 g-4 mb-5">
		@foreach (var agent in Model)
		{
			<div class="col">
				<a asp-controller="Agent" asp-action="Details" asp-route-id="@agent.Id" class="text-decoration-none agent-link">
					<div class="d-flex flex-column h-100">
                    
						<div class="agent-img-wrapper mb-3 overflow-hidden rounded-4">
							<img src="@agent.AvatarUrl"
								 class="w-100 h-100 object-fit-cover agent-img"
								 alt="Снимка на @agent.FullName"
								 onerror="this.src='/images/default-avatar.png'">
						</div>
                    
						<div class="agent-info d-flex flex-column flex-grow-1 px-1">
							<h6 class="fw-bold mb-2 text-dark" style="font-size: 0.95rem; line-height: 1.3;">
								@agent.FullName
							</h6>
                        
							<div class="d-flex align-items-center mb-1 text-muted" style="font-size: 0.8rem;">
								<i class="bi bi-geo-alt me-2 fs-6"></i>
								<span class="text-truncate" title="@agent.Address">@agent.Address</span>
							</div>
                        
							<div class="d-flex align-items-center text-muted" style="font-size: 0.8rem;">
								<i class="bi bi-telephone me-2 fs-6"></i>
								<span>@agent.PhoneNumber</span>
							</div>
						</div>

					</div>
				</a>
			</div>
		}
	</div>

	<div class="d-flex justify-content-center mt-5">
		<nav aria-label="Page navigation">
			<ul class="pagination pagination-sm gap-2 align-items-center mb-0">
				<li class="page-item disabled">
					<a class="page-link rounded-circle border-0 text-dark bg-light shadow-sm pagination-circle" href="#" tabindex="-1">
						<i class="bi bi-chevron-left"></i>
					</a>
				</li>
				<li class="page-item active">
					<a class="page-link rounded-circle border-0 text-white shadow-sm pagination-circle" href="#" style="background-color: #009688;">1</a>
				</li>
				<li class="page-item">
					<a class="page-link rounded-circle border-0 text-dark bg-white shadow-sm pagination-circle" href="#">2</a>
				</li>
				<li class="page-item">
					<a class="page-link rounded-circle border-0 text-dark bg-white shadow-sm pagination-circle" href="#">3</a>
				</li>
				<li class="page-item">
					<a class="page-link rounded-circle border-0 text-dark bg-white shadow-sm pagination-circle" href="#">
						<i class="bi bi-chevron-right"></i>
					</a>
				</li>
			</ul>
		</nav>
	</div>
</div>

@section Styles {
	<link rel="stylesheet" href="~/css/agents.css">
	}