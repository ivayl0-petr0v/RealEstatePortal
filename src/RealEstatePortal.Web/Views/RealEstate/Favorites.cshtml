@model IEnumerable<FavoriteRealEstateViewModel>

@{
	ViewData["Title"] = "My Favorite Properties";
}

<div class="container mt-5 mb-5">
	<div class="mb-4">
		<h2 class="fw-bold"><i class="bi bi-heart-fill text-danger me-2"></i>My Favorites</h2>
		<p class="text-muted">You have saved @Model.Count() properties</p>
	</div>

	@if (!Model.Any())
	{
		<div class="form-card text-center py-5">
			<i class="bi bi-house-heart text-muted" style="font-size: 3rem;"></i>
			<h4 class="mt-3">No favorites yet</h4>
			<p class="text-muted">Explore our properties and click the heart icon to save them here.</p>
			<a asp-action="Index" class="btn btn-theme mt-2">Browse Properties</a>
		</div>
	}
	else
	{
		<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
			@foreach (var property in Model)
			{
				<div class="col" id="favorite-card-@property.Id">
					<div class="card h-100 border-0 shadow-sm property-card position-relative overflow-hidden">
                        
						<form asp-controller="RealEstate" asp-action="ToggleFavorite" asp-route-id="@property.Id" method="post" class="position-absolute top-0 end-0 m-3" style="z-index: 10;">
							<input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
							<button type="submit" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center heart-btn" style="width: 36px; height: 36px;">
								<i class="bi bi-heart-fill text-danger fs-6"></i>
							</button>
						</form>

						<a asp-action="Details" asp-route-id="@property.Id" class="text-decoration-none text-dark">
							<img src="@property.ImageUrl" class="card-img-top object-fit-cover" style="height: 200px;" alt="@property.Title" onerror="this.src='/images/default-property.jpg'">
                            
							<div class="card-body p-3">
								<h5 class="fw-bold mb-2" style="color: #008C72;">@property.Price.ToString("N0") €</h5>
								<h6 class="fw-bold text-truncate">@property.Title</h6>
								<p class="text-muted small mb-0 text-truncate"><i class="bi bi-geo-alt me-1"></i> @property.Address</p>
							</div>
						</a>
					</div>
				</div>
			}
		</div>
	}
</div>