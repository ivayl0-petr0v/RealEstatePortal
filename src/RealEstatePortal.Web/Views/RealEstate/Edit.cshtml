@model RealEstateFormModel

@{
	ViewData["Title"] = "Edit Property";
}

<div class="container py-5">
	<h2 class="mb-4 fw-bold">Edit Property</h2>

	<form asp-action="Edit" method="post" enctype="multipart/form-data">
		<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

		<div class="row">
			<div class="col-lg-7">
                
				<div class="form-card">
					<h5>General Information</h5>
                    
					<div class="mb-3">
						<label asp-for="TransactionType" class="form-label-custom">Transaction Type</label>
						<select asp-for="TransactionType" class="form-select">
							<option value="Sale">Sale</option>
							<option value="Rent">Rent</option>
						</select>
						<span asp-validation-for="TransactionType" class="text-danger small"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Price" class="form-label-custom">Price (€)</label>
						<input asp-for="Price" class="form-control" placeholder="e.g. 147000" />
						<span asp-validation-for="Price" class="text-danger small"></span>
					</div>

					<div class="mb-3">
						<label asp-for="CategoryId" class="form-label-custom">Property Type</label>
						<select asp-for="CategoryId" class="form-select">
							<option value="">Select...</option>
							@foreach (var category in Model.Categories)
							{
								<option value="@category.Id">@category.Name</option>
							}
						</select>
						<span asp-validation-for="CategoryId" class="text-danger small"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Area" class="form-label-custom">Area (m²)</label>
						<input asp-for="Area" class="form-control" placeholder="e.g. 70" />
						<span asp-validation-for="Area" class="text-danger small"></span>
					</div>

					<div class="row mb-3">
						<div class="col-md-4">
							<label asp-for="CityId" class="form-label-custom">City</label>
							<select asp-for="CityId" class="form-select">
								<option value="">Select...</option>
								@foreach (var city in Model.Cities)
								{
									<option value="@city.Id">@city.Name</option>
								}
							</select>
							<span asp-validation-for="CityId" class="text-danger small"></span>
						</div>
						<div class="col-md-8">
							<label asp-for="Address" class="form-label-custom">Address / Neighborhood</label>
							<input asp-for="Address" class="form-control" placeholder="e.g. Downtown" />
							<span asp-validation-for="Address" class="text-danger small"></span>
						</div>
					</div>

					<div class="row">
						<div class="col-md-4 mb-3 mb-md-0">
							<label asp-for="RoomsCount" class="form-label-custom">Rooms</label>
							<input asp-for="RoomsCount" class="form-control" placeholder="3" />
							<span asp-validation-for="RoomsCount" class="text-danger small"></span>
						</div>
						<div class="col-md-4 mb-3 mb-md-0">
							<label asp-for="BedroomsCount" class="form-label-custom">Bedrooms</label>
							<input asp-for="BedroomsCount" class="form-control" placeholder="2" />
							<span asp-validation-for="BedroomsCount" class="text-danger small"></span>
						</div>
						<div class="col-md-4">
							<label asp-for="BathroomsCount" class="form-label-custom">Bathrooms</label>
							<input asp-for="BathroomsCount" class="form-control" placeholder="1" />
							<span asp-validation-for="BathroomsCount" class="text-danger small"></span>
						</div>
					</div>
				</div>

				<div class="form-card">
					<h5>Facts and Details</h5>
					<div class="row mb-3">
						<div class="col-md-6">
							<label asp-for="ConstructionType" class="form-label-custom">Construction Type</label>
							<input asp-for="ConstructionType" class="form-control" placeholder="e.g. Brick" />
							<span asp-validation-for="ConstructionType" class="text-danger small"></span>
						</div>
						<div class="col-md-6">
							<label asp-for="ConstructionYear" class="form-label-custom">Construction Year</label>
							<input asp-for="ConstructionYear" class="form-control" placeholder="2020" />
							<span asp-validation-for="ConstructionYear" class="text-danger small"></span>
						</div>
					</div>

					<div class="row mb-3">
						<div class="col-md-6">
							<label asp-for="CompletionStatus" class="form-label-custom">Completion Status</label>
							<input asp-for="CompletionStatus" class="form-control" placeholder="e.g. Completed" />
							<span asp-validation-for="CompletionStatus" class="text-danger small"></span>
						</div>
						<div class="col-md-6">
							<label asp-for="Furnishing" class="form-label-custom">Furnishing</label>
							<input asp-for="Furnishing" class="form-control" placeholder="e.g. Fully furnished" />
							<span asp-validation-for="Furnishing" class="text-danger small"></span>
						</div>
					</div>

					<h6 class="mt-4 mb-3 fw-bold text-dark">Floors</h6>
					<div class="row">
						<div class="col-md-6">
							<label asp-for="TotalFloors" class="form-label-custom">Total Floors in Building</label>
							<input asp-for="TotalFloors" class="form-control" placeholder="8" />
							<span asp-validation-for="TotalFloors" class="text-danger small"></span>
						</div>
						<div class="col-md-6">
							<label asp-for="RealEstateFloor" class="form-label-custom">Property Floor</label>
							<input asp-for="RealEstateFloor" class="form-control" placeholder="2" />
							<span asp-validation-for="RealEstateFloor" class="text-danger small"></span>
						</div>
					</div>

					<h6 class="mt-4 mb-3 fw-bold text-dark">Exposure</h6>
					<div class="d-flex flex-column gap-2">
						@foreach (var exposure in new[] { "East", "West", "North", "South" })
						{
							<div class="form-check">
								<input type="checkbox" name="SelectedExposures" value="@exposure" class="form-check-input" id="exp_@exposure"
								@(Model.SelectedExposures != null && Model.SelectedExposures.Contains(exposure) ? "checked" : "") />
								<label class="form-check-label" for="exp_@exposure">@exposure</label>
							</div>
						}
					</div>
				</div>

				<div class="form-card">
					<h5>Amenities</h5>
					<div class="d-flex flex-column gap-2">
						@foreach (var feature in Model.Features)
						{
							<div class="col-md-4 col-sm-6 mb-2">
								<div class="form-check custom-checkbox">
									<input class="form-check-input" type="checkbox" name="SelectedFeatureIds" value="@feature.Id" id="feature_@feature.Id"
									@(Model.SelectedFeatureIds != null && Model.SelectedFeatureIds.Contains(feature.Id) ? "checked" : "")>
									<label class="form-check-label text-muted" for="feature_@feature.Id">
										@feature.Name
									</label>
								</div>
							</div>
						}
					</div>
				</div>

			</div>

			<div class="col-lg-5">
    
				<div class="form-card">
					<h5>Gallery</h5>
        
					@if (Model.ExistingImageUrls != null && Model.ExistingImageUrls.Any())
					{
						<div class="mb-4 p-3 bg-light rounded-3 border">
							<label class="form-label fw-bold small text-muted text-uppercase mb-2">Current Images</label>
        
							<div class="d-flex flex-wrap gap-2" id="existingImagesContainer">
								@foreach (var imgUrl in Model.ExistingImageUrls)
								{
									<div class="position-relative existing-image-wrapper">
										<img src="@imgUrl" class="rounded object-fit: cover shadow-sm border" style="width: 80px; height: 80px;" alt="Property Image">
                    
										<button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 rounded-circle p-0 d-flex align-items-center justify-content-center shadow remove-existing-img"
												style="width: 22px; height: 22px; margin-top: -8px; margin-right: -8px;"
												data-url="@imgUrl" title="Remove image">
											<i class="bi bi-x" style="pointer-events: none;"></i>
										</button>
									</div>
								}
							</div>
        
							<div id="removedImagesInputs"></div>
        
						</div>
					}

					<label class="form-label fw-bold small text-muted text-uppercase mb-2">Upload New Images</label>
					<input type="file" asp-for="Images" id="imageInput" class="d-none" multiple accept="image/*" />
        
					<div class="gallery-upload-box" id="galleryBox">
						<i class="bi bi-camera fs-2 text-muted"></i>
						<p class="text-muted mt-2 mb-0 small">Click here to upload new images</p>
					</div>
					<span asp-validation-for="Images" class="text-danger small"></span>

					<div class="gallery-preview" id="previewContainer"></div>
				</div>

				<div class="form-card">
					<h5>Property Description</h5>
					<textarea asp-for="Description" class="form-control" rows="8" placeholder="Enter a detailed description of the property..."></textarea>
					<span asp-validation-for="Description" class="text-danger small"></span>
				</div>

				<div class="text-end mb-5">
					<button type="submit" class="btn btn-theme border-0 shadow-sm w-100 py-2 fw-bold">Save changes</button>
				</div>

			</div>
		</div>
	</form>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script src="~/js/real-estate-gallery.js" asp-append-version="true"></script>
	<script src="~/js/real-estate-detele-img.js" asp-append-version="true"></script>
}