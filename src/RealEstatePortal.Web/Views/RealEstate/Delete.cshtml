@model RealEstateDeleteViewModel

@{
	ViewData["Title"] = "Delete Property";
}

<div class="container py-5">
	<div class="row justify-content-center">
		<div class="col-md-8 col-lg-6">
            
			<div class="card border-0 shadow-lg rounded-4 overflow-hidden">
				<div class="bg-danger text-white p-4 text-center">
					<i class="bi bi-exclamation-triangle display-3 mb-2"></i>
					<h2 class="fw-bold mb-0">Confirm Delete</h2>
				</div>

				<div class="card-body p-4 p-md-5 bg-white">
					<p class="text-center fs-5 text-muted mb-4">
						Are you sure you want to delete this property listing? <br />
						<span class="text-danger fw-medium">This action cannot be undone.</span>
					</p>

					<div class="d-flex align-items-center bg-light border rounded-3 p-3 mb-4">
						<img src="@Model.ImageUrl" alt="@Model.Title" class="rounded-3 object-fit-cover shadow-sm me-3" style="width: 100px; height: 100px;">
                        
						<div>
							<h5 class="fw-bold mb-1 text-dark">@Model.Title</h5>
							<p class="text-muted small mb-2"><i class="bi bi-geo-alt me-1"></i>@Model.Address</p>
							<h6 class="fw-bold text-theme mb-0">@Model.Price.ToString("N0") €</h6>
						</div>
					</div>

					<form asp-action="Delete" method="post">
						<input type="hidden" asp-for="Id" />
                        
						<div class="d-flex gap-3 mt-2">
							<a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill py-2 w-50 fw-medium">
								Cancel
							</a>
							<button type="submit" class="btn btn-danger rounded-pill py-2 w-50 fw-bold shadow-sm">
								<i class="bi bi-trash me-2"></i>Delete Listing
							</button>
						</div>
					</form>
				</div>
			</div>

		</div>
	</div>
</div>