@model AllRealEstatesQueryModel

@{
	ViewData["Title"] = "Properties";
}

<div class="container mt-5 mb-5">
    
	<div class="mb-4">
		<h2 class="mb-1 fw-bold">Properties</h2>
		<p class="text-muted">@Model.RealEstates.Count() properties</p>
	</div>

	<form method="get" asp-controller="RealEstate" asp-action="Index">
		<div class="row g-3 mb-5">
			<div class="col-lg-7">
				<div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 py-2">
					<i class="bi bi-search text-muted ms-2 me-3 fs-5"></i>
					<input type="text" asp-for="SearchTerm" class="form-control border-0 shadow-none bg-transparent p-0" placeholder="Search location, property type...">
						<button type="submit" class="btn btn-light rounded-circle ms-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
							<i class="bi bi-sliders text-dark"></i>
						</button>
					</div>
				</div>

				<div class="col-lg-2">
					<div class="bg-white rounded-pill shadow-sm px-3 py-2 d-flex align-items-center h-100">
						<select asp-for="TransactionType" class="form-select border-0 shadow-none bg-transparent p-0 fw-medium cursor-pointer" onchange="this.form.submit()">
							<option value="">All Types</option>
							<option value="Sale">For Sale</option>
							<option value="Rent">For Rent</option>
						</select>
					</div>
				</div>

				<div class="col-lg-3">
					<div class="bg-white rounded-pill shadow-sm px-4 py-2 d-flex align-items-center h-100">
						<div class="w-100">
							<span class="d-block text-muted" style="font-size: 0.7rem; margin-bottom: -4px;">Sort by</span>
							<select asp-for="Sorting" class="form-select border-0 shadow-none bg-transparent p-0 fw-medium cursor-pointer" onchange="this.form.submit()">
								<option value="newest">Newest</option>
								<option value="price_asc">Price: Low to High</option>
								<option value="price_desc">Price: High to Low</option>
							</select>
						</div>
					</div>
				</div>
			</div>
		</form>
		@if (!Model.RealEstates.Any())
		{
			<div class="text-center py-5 my-5">
				<div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-4 shadow-sm" style="width: 120px; height: 120px;">
					<i class="bi bi-house-x text-muted" style="font-size: 3rem;"></i>
				</div>
				<h3 class="fw-bold mb-3">No properties found</h3>
				<p class="text-muted mb-4">We couldn't find any properties matching your current search criteria. Try adjusting your filters or clear them to see all available listings.</p>
            
				<a asp-controller="RealEstate" asp-action="Index" class="btn rounded-pill px-4 py-2 text-white shadow-sm" style="background-color: #009688;">
					<i class="bi bi-arrow-counterclockwise me-2"></i> Clear all filters
				</a>
			</div>
		}
		else
		{
			<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
				@foreach (var property in Model.RealEstates)
				{
					<div class="col">
						<a asp-controller="RealEstate" asp-action="Details" asp-route-id="@property.Id" class="text-decoration-none">
							<div class="card h-100 border-0 shadow-sm overflow-hidden property-card position-relative">
                            
								<form asp-action="ToggleFavorite" asp-route-id="@property.Id" method="post" class="position-absolute top-0 end-0 m-3" style="z-index: 10;">
									<input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
    
									<button type="submit" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center heart-btn" style="width: 36px; height: 36px;">
										<i class="bi @(property.IsFavorite ? "bi-heart-fill text-danger" : "bi-heart text-dark") fs-6"></i>
									</button>
								</form>

								<img src="@property.ImageUrl" class="card-img-top object-fit-cover" style="height: 240px;" alt="@property.Title" onerror="this.src='/images/default-property.jpg'">
                            
								<div class="card-body p-3 d-flex flex-column">
									<h5 class="fw-bold mb-3" style="color: #009688;">@property.Price.ToString("N0") €</h5>
                                
									<div class="d-flex flex-wrap align-items-center text-muted small mb-2 gap-3">
										<span class="d-flex align-items-center"><i class="bi bi-house me-1"></i> @property.Title</span>
										<span class="d-flex align-items-center"><i class="bi bi-arrows-fullscreen me-1"></i> @property.Area m²</span>
										<span class="d-flex align-items-center text-truncate" style="max-width: 140px;" title="@property.Address"><i class="bi bi-geo-alt me-1"></i> @property.Address</span>
									</div>
                                
									<div class="d-flex flex-wrap align-items-center text-muted small gap-3 mt-auto">
										<span class="d-flex align-items-center"><i class="bi bi-door-open me-1"></i> @property.RoomsCount rooms</span>
										<span class="d-flex align-items-center"><i class="fas fa-bed me-1" style="font-size: 0.9rem;"></i> @property.BedroomsCount beds</span>
										<span class="d-flex align-items-center"><i class="bi bi-droplet me-1"></i> @property.BathroomsCount baths</span>
									</div>
								</div>
							</div>
						</a>
					</div>
				}
			</div>
        
			int maxPage = (int)Math.Ceiling((double)Model.TotalRealEstatesCount / Model.RealEstatesPerPage);
			if (maxPage == 0) maxPage = 1;

			<div class="d-flex justify-content-center mt-5 mb-5">
				<nav aria-label="Page navigation">
					<ul class="pagination pagination-sm gap-2 align-items-center mb-0">
                    
						<li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
							<a class="page-link rounded-circle border-0 text-dark bg-light shadow-sm pagination-circle"
								   asp-controller="RealEstate"
								   asp-action="Index"
								   asp-route-CurrentPage="@(Model.CurrentPage - 1)"
								   asp-route-SearchTerm="@Model.SearchTerm"
								   asp-route-TransactionType="@Model.TransactionType"
								   asp-route-Sorting="@Model.Sorting">
								<i class="bi bi-chevron-left"></i>
							</a>
						</li>

						@for (int i = 1; i <= maxPage; i++)
						{
							<li class="page-item @(Model.CurrentPage == i ? "active" : "")">
								<a class="page-link rounded-circle border-0 shadow-sm pagination-circle @(Model.CurrentPage == i ? "text-white" : "text-dark bg-white")"
									   style="@(Model.CurrentPage == i ? "background-color: #009688;" : "")"
									   asp-controller="RealEstate"
									   asp-action="Index"
									   asp-route-CurrentPage="@i"
									   asp-route-SearchTerm="@Model.SearchTerm"
									   asp-route-TransactionType="@Model.TransactionType"
									   asp-route-Sorting="@Model.Sorting">
									@i
								</a>
							</li>
						}

						<li class="page-item @(Model.CurrentPage == maxPage ? "disabled" : "")">
							<a class="page-link rounded-circle border-0 text-dark bg-light shadow-sm pagination-circle"
								   asp-controller="RealEstate"
								   asp-action="Index"
								   asp-route-CurrentPage="@(Model.CurrentPage + 1)"
								   asp-route-SearchTerm="@Model.SearchTerm"
								   asp-route-TransactionType="@Model.TransactionType"
								   asp-route-Sorting="@Model.Sorting">
								<i class="bi bi-chevron-right"></i>
							</a>
						</li>
                    
					</ul>
				</nav>
			</div>
		}
	</div>