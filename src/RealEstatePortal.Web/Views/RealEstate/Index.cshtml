@model IEnumerable<AllRealEstatesViewModel>

@{
    ViewData["Title"] = "Properties for sale";
}

<div class="container mt-5 mb-5">
    
    <div class="mb-4">
        <h2 class="mb-1 fw-bold">Properties for sale</h2>
        <p class="text-muted">@Model.Count() properties</p>
    </div>

    <div class="row g-3 mb-5">
        <div class="col-lg-9">
            <div class="d-flex align-items-center bg-white rounded-pill shadow-sm px-3 py-2">
                <i class="bi bi-search text-muted ms-2 me-3 fs-5"></i>
                <input type="text" class="form-control border-0 shadow-none bg-transparent p-0" placeholder="Search location, property type...">
                <button class="btn btn-light rounded-circle ms-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="bi bi-sliders text-dark"></i>
                </button>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="bg-white rounded-pill shadow-sm px-4 py-2 d-flex align-items-center h-100">
                <div class="w-100">
                    <span class="d-block text-muted" style="font-size: 0.7rem; margin-bottom: -4px;">Sort by</span>
                    <select class="form-select border-0 shadow-none bg-transparent p-0 fw-medium cursor-pointer">
                        <option value="newest">Newest</option>
                        <option value="price_asc">Price: Low to High</option>
                        <option value="price_desc">Price: High to Low</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
        @foreach (var property in Model)
        {
            <div class="col">
                <a asp-controller="RealEstate" asp-action="Details" asp-route-id="@property.Id" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm overflow-hidden property-card position-relative">
                        
                        <button class="btn btn-light rounded-circle position-absolute top-0 end-0 m-3 shadow-sm d-flex align-items-center justify-content-center heart-btn" style="width: 36px; height: 36px; z-index: 2;">
                            <i class="bi bi-heart text-dark fs-6"></i>
                        </button>

                        <img src="@property.ImageUrl" class="card-img-top object-fit-cover" style="height: 240px;" alt="@property.Title" onerror="this.src='/images/default-property.jpg'">
                        
                        <div class="card-body p-3">
                            <h5 class="fw-bold mb-3" style="color: #009688;">@property.Price.ToString("N0") €</h5>
                            
                            <div class="d-flex flex-wrap align-items-center text-muted small mb-2 gap-3">
                                <span class="d-flex align-items-center"><i class="bi bi-house me-1"></i> @property.Title</span>
                                <span class="d-flex align-items-center"><i class="bi bi-arrows-fullscreen me-1"></i> @property.Area m²</span>
                                <span class="d-flex align-items-center text-truncate" style="max-width: 140px;" title="@property.Address"><i class="bi bi-geo-alt me-1"></i> @property.Address</span>
                            </div>
                            
                            <div class="d-flex flex-wrap align-items-center text-muted small gap-3">
                                <span class="d-flex align-items-center"><i class="bi bi-door-open me-1"></i> @property.RoomsCount rooms</span>
                                <span class="d-flex align-items-center"><i class="bi bi-bed me-1"></i> @property.BedroomsCount beds</span>
                                <span class="d-flex align-items-center"><i class="bi bi-droplet me-1"></i> @property.BathroomsCount baths</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    <div class="d-flex justify-content-center mt-5 mb-5">
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm gap-2 align-items-center mb-0">
                <li class="page-item disabled">
                    <a class="page-link rounded-circle border-0 text-dark bg-light shadow-sm pagination-circle" href="#" tabindex="-1">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                <li class="page-item active">
                    <a class="page-link rounded-circle border-0 text-white shadow-sm pagination-circle" href="#" style="background-color: #009688;">1</a>
                </li>
                <li class="page-item">
                    <a class="page-link rounded-circle border-0 text-dark bg-white shadow-sm pagination-circle" href="#">2</a>
                </li>
                <li class="page-item">
                    <a class="page-link rounded-circle border-0 text-dark bg-white shadow-sm pagination-circle" href="#">3</a>
                </li>
                <li class="page-item">
                    <a class="page-link rounded-circle border-0 text-dark bg-white shadow-sm pagination-circle" href="#">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>